package com.samduka.dukacred.feature.dashboard.presentation

import androidx.lifecycle.ViewModel
import kotlinx.coroutines.flow.MutableSharedFlow
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.asSharedFlow
import kotlinx.coroutines.flow.asStateFlow

/**
 * The brain of the DukaCred Home Dashboard.
 * Routes merchant actions to navigations or data refreshes.
 */
class DashboardViewModel : ViewModel() {

    // 1. The Single Source of Truth for the UI
    private val _state = MutableStateFlow(DashboardState())
    val state = _state.asStateFlow()

    // 2. The One-Time Event Channel (Navigations)
    private val _effect = MutableSharedFlow<DashboardEffect>()
    val effect = _effect.asSharedFlow()

    // 3. The switchboard for merchant actions
    fun onIntent(intent: DashboardIntent) {
        when (intent) {
            is DashboardIntent.RefreshDashboard -> {
                // TODO: Fetch updated daily sales and stock counts
                _state.value = _state.value.copy(isLoading = true)
            }
            is DashboardIntent.QuickScanClicked -> {
                // TODO: Emit NavigateToScanner effect
            }
            is DashboardIntent.InventoryShortcutClicked -> {
                // TODO: Emit NavigateToInventory effect
            }
        }
    }
}